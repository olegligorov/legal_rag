# Set USE_OLLAMA=true to use a local Ollama instance instead of Claude
USE_OLLAMA=false

# Claude (default)
CLAUDE_API_KEY=your-api-key-here
CLAUDE_MODEL=anthropic--claude-4.5-haiku
CLAUDE_URL=http://localhost:6655

# Ollama (only used when USE_OLLAMA=true)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# == Models ==================================================================
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/BGE-Reranker-v2-M3
LLM_TEMPERATURE=0.2

# == Retrieval ==================================================================
VECTOR_RETRIEVAL_K=25
BM25_RETRIEVAL_K=25

# == Chunking ==================================================================─
CHUNK_MAX_CHARS=600
CHUNK_OVERLAP_CHARS=80

# == Reranker ==================================================================─
# Score is sigmoid-normalized to [0, 1]; 0.5 = neutral.
RERANKER_TOP_N=5
RERANKER_SCORE_THRESHOLD=0.4
MIN_RETRIEVED_DOCS=1
